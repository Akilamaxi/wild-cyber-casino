# startup.sh and startup.bat generate .env and unique secrets automatically.
# These markers intentionally prevent this template from being used as credentials.
JWT_SECRET=GENERATE_ON_FIRST_START
POSTGRES_PASSWORD=GENERATE_ON_FIRST_START
REDIS_PASSWORD=GENERATE_ON_FIRST_START
CORS_ORIGINS=http://localhost:8080
ADMIN_CORS_ORIGINS=http://localhost:8080
