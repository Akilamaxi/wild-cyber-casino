# Non-secret deployment inputs. Source this file after replacing the examples.
PROJECT_ID=your-google-cloud-project
REGION=us-central1
SERVICE_NAME=secure-casino-spinwheel
ARTIFACT_REPOSITORY=casino
RUNTIME_SERVICE_ACCOUNT=casino-run@your-google-cloud-project.iam.gserviceaccount.com
CLOUD_SQL_INSTANCE=your-google-cloud-project:us-central1:casino-postgres
SQL_INSTANCE_NAME=casino-postgres
CLOUD_ARMOR_POLICY=casino-edge-security
PGUSER=casino_app
PGDATABASE=cyber_casino

# Existing Secret Manager secret names. Their values are never stored here.
JWT_SECRET_NAME=casino-jwt-secret
PGPASSWORD_SECRET_NAME=casino-db-password
REDIS_URL_SECRET_NAME=casino-redis-url
PAYMENT_WEBHOOK_SECRET_NAME=casino-payment-webhook-secret
ADMIN_MFA_SECRET_NAME=casino-admin-mfa-secret
AUDIT_HMAC_SECRET_NAME=casino-audit-hmac-secret

# Optional Direct VPC egress configuration for Memorystore/private Redis.
VPC_NETWORK=default
VPC_SUBNET=default
